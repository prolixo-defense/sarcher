DATABASE_URL=sqlite:///./data/networking.db
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
DEFAULT_RETENTION_DAYS=180

# Phase 2 - Scraping Config
LINKEDIN_LI_AT_COOKIE=           # Your LinkedIn li_at session cookie
SCRAPE_DELAY_MIN=1.0             # Minimum seconds between requests
SCRAPE_DELAY_MAX=5.0             # Maximum seconds between requests
LINKEDIN_DAILY_LIMIT=80          # Max LinkedIn profiles per day
PROXY_FILE=./data/proxies.txt    # Path to proxy list file
SCREENSHOT_DIR=./data/screenshots # Debug screenshots directory
HEADLESS=true                    # Run browser in headless mode

# Phase 3 - LLM Config
LLM_PROVIDER=ollama                    # ollama (free), openai, anthropic
LLM_MODEL=ollama/llama3.1:8b          # Model to use for extraction
LLM_BASE_URL=http://localhost:11434    # Ollama default
LLM_TEMPERATURE=0.1                    # Low temp for deterministic extraction
LLM_MAX_TOKENS=4000                    # Max tokens per extraction call

# Phase 3 - Enrichment APIs
APOLLO_API_KEY=                        # Free account: apollo.io
APOLLO_MONTHLY_BUDGET=10000            # Free tier credits
HUNTER_API_KEY=                        # Free account: hunter.io
HUNTER_MONTHLY_BUDGET=25               # Free tier searches
ENRICHMENT_PRIMARY=apollo
ENRICHMENT_FALLBACK=hunter
ENRICH_PHONE=false                     # Phone lookups cost more credits

# Phase 4 - Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SENDER_NAME=Your Name
SENDER_EMAIL=your-email@gmail.com
DAILY_EMAIL_LIMIT=50
DAILY_LINKEDIN_LIMIT=25

# Phase 4 - Business Hours
BUSINESS_HOURS_START=9
BUSINESS_HOURS_END=18
TIMEZONE=America/New_York
BUSINESS_DAYS=mon,tue,wed,thu,fri

# Phase 4 - Compliance
RESPECT_ROBOTS=true
PRIVACY_NOTICE_URL=https://yoursite.com/privacy
PHYSICAL_ADDRESS=Your Address Here

# Phase 4 - RAG / Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma
